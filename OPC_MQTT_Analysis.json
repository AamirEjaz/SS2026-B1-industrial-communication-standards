    {
        "id": "5f71d86599c06422",
        "type": "function",
        "z": "d4eb480a7a3c4fbb",
        "name": "Calculate MQTT Latency",
        "func": "const EXPECTED_TOKEN = \"SEMINAR-SECURE-KEY-2026\";\nlet receiveTime = Date.now();\nlet parts = String(msg.payload).split(\"|\");\n\n\nif (parts.length < 3 || parts[2] !== EXPECTED_TOKEN) {\n    msg.payload = \"🚨 ATTACK BLOCKED | Unauthorized payload: \" + parts[0];\n    node.status({fill:\"red\", shape:\"dot\", text:\"Intrusion Blocked!\"});\n    return msg; \n}\n\n\nlet data = parts[0];\nlet sendTime = parseInt(parts[1]);\nlet latency = receiveTime - sendTime;\n\nmsg.payload = \"Latency: \" + latency + \" ms | Data: \" + data + \"°C | ✅ VERIFIED\";\nnode.status({fill:\"green\", shape:\"dot\", text:\"Secure Data Passed\"});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1310,
        "y": 220,
        "wires": [
            [
                "dbb8a5d9f55e6529",
                "1dfea802c9204717"
            ]
        ]
    },
    {
        "id": "48882cf3ebb6c527",
        "type": "function",
        "z": "d4eb480a7a3c4fbb",
        "name": "Calculate OPC Latency",
        "func": "const EXPECTED_TOKEN = \"SEMINAR-SECURE-KEY-2026\";\nlet receiveTime = Date.now();\n\n\nif (!msg.topic || msg.topic !== \"ns=1;s=MachineTemp\") return null;\n\nlet raw = msg.payload;\nif (Array.isArray(raw)) raw = raw[0];\nif (raw && raw.value !== undefined) raw = raw.value;\nif (raw && raw.value !== undefined) raw = raw.value; \n\nlet parts = String(raw).split(\"|\");\n\n\n\nif (parts.length < 3 || parts[2] !== EXPECTED_TOKEN) {\n    msg.payload = \"🚨 ATTACK BLOCKED | Unauthorized payload: \" + parts[0];\n    node.status({fill:\"red\", shape:\"dot\", text:\"Intrusion Blocked!\"});\n    return msg; \n}\n\nlet data = parseFloat(parts[0]).toFixed(2);\nlet sendTime = parseInt(parts[1]);\nlet latency = receiveTime - sendTime;\n\nmsg.payload = \"Latency: \" + latency + \" ms | Data: \" + data + \"°C | ✅ VERIFIED\";\nnode.status({fill:\"green\", shape:\"dot\", text:\"Secure Data Passed\"});\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1410,
        "y": 480,
        "wires": [
