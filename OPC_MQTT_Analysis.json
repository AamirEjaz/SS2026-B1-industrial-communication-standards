    {
        "id": "3abbf5c0b2dcf62c",
        "type": "function",
        "z": "d4eb480a7a3c4fbb",
        "name": "Alternating Sensor",
        "func": "let count = flow.get('mqtt_count') || 0;\ncount++;\n\nconst SECRET_TOKEN = \"SEMINAR-SECURE-KEY-2026\"; \n\nlet temp = (80 + (Math.random() * 10 - 5)).toFixed(2);\nlet timeStamp = Date.now();\n\nmsg.payload = temp + \"|\" + timeStamp + \"|\" + SECRET_TOKEN;\nflow.set('mqtt_count', count);\n\nnode.status({fill: \"green\", shape: \"dot\", text: \"Signed & Transmitted (\" + count + \")\"});\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 220,
